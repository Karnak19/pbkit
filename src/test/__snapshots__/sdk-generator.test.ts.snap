"// Generated by pbkit — do not edit

import type PocketBase from "pocketbase"
import type { UsersRecord, UsersCreate, UsersUpdate, CategoriesRecord, CategoriesCreate, CategoriesUpdate, ArticlesRecord, ArticlesCreate, ArticlesUpdate, CommentsRecord, CommentsCreate, CommentsUpdate } from "./types"

export type PbClient = PocketBase

export interface ListResult<T> {
  page: number
  perPage: number
  totalItems: number
  totalPages: number
  items: T[]
}

export interface ListParams {
  page?: number
  perPage?: number
  sort?: string
  filter?: string
  expand?: string
  fields?: string
}

export interface RequestOptions {
  expand?: string
  filter?: string
  sort?: string
  fields?: string
}

// --- Users ---

export async function getUser(pb: PbClient, id: string, options?: RequestOptions): Promise<UsersRecord> {
  return pb.collection("users").getOne(id, options) as Promise<UsersRecord>
}

export async function getFirstUser(pb: PbClient, filter: string, options?: RequestOptions): Promise<UsersRecord> {
  return pb.collection("users").getFirstListItem(filter, options) as Promise<UsersRecord>
}

export async function listUsers(pb: PbClient, params?: ListParams): Promise<ListResult<UsersRecord>> {
  return pb.collection("users").getList(params?.page, params?.perPage, params) as Promise<ListResult<UsersRecord>>
}

export async function getFullListUsers(pb: PbClient, params?: ListParams): Promise<UsersRecord[]> {
  return pb.collection("users").getFullList(params) as Promise<UsersRecord[]>
}

export async function createUser(pb: PbClient, data: UsersCreate): Promise<UsersRecord> {
  return pb.collection("users").create(data) as Promise<UsersRecord>
}

export async function updateUser(pb: PbClient, id: string, data: UsersUpdate): Promise<UsersRecord> {
  return pb.collection("users").update(id, data) as Promise<UsersRecord>
}

export async function deleteUser(pb: PbClient, id: string): Promise<true> {
  await pb.collection("users").delete(id)
  return true
}

export async function authUserWithPassword(pb: PbClient, usernameOrEmail: string, password: string): Promise<UsersRecord> {
  const result = await pb.collection("users").authWithPassword(usernameOrEmail, password)
  return result.record as unknown as UsersRecord
}

export async function authUserWithOAuth2(pb: PbClient, provider: string, code: string, codeVerifier: string, redirectUrl: string): Promise<UsersRecord> {
  const result = await pb.collection("users").authWithOAuth2Code(provider, code, codeVerifier, redirectUrl)
  return result.record as unknown as UsersRecord
}

export async function authUserWithOTP(pb: PbClient, otpId: string, password: string): Promise<UsersRecord> {
  const result = await pb.collection("users").authWithOTP(otpId, password)
  return result.record as unknown as UsersRecord
}

export async function requestUserPasswordReset(pb: PbClient, email: string): Promise<true> {
  await pb.collection("users").requestPasswordReset(email)
  return true
}

export async function confirmUserPasswordReset(pb: PbClient, token: string, password: string, passwordConfirm: string): Promise<true> {
  await pb.collection("users").confirmPasswordReset(token, password, passwordConfirm)
  return true
}

export async function requestUserVerification(pb: PbClient, email: string): Promise<true> {
  await pb.collection("users").requestVerification(email)
  return true
}

export async function confirmUserVerification(pb: PbClient, token: string): Promise<true> {
  await pb.collection("users").confirmVerification(token)
  return true
}

export async function requestUserEmailChange(pb: PbClient, newEmail: string): Promise<true> {
  await pb.collection("users").requestEmailChange(newEmail)
  return true
}

export async function confirmUserEmailChange(pb: PbClient, token: string, password: string): Promise<true> {
  await pb.collection("users").confirmEmailChange(token, password)
  return true
}

export async function refreshUser(pb: PbClient): Promise<UsersRecord> {
  const result = await pb.collection("users").authRefresh()
  return result.record as unknown as UsersRecord
}

