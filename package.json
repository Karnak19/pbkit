{
  "name": "@karnak19/pbkit",
  "version": "0.0.1",
  "description": "PocketBase code generation toolkit",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pbkit": "dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir=dist --target=node && tsc --emitDeclarationOnly",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "^1.2.0"
  }
}
